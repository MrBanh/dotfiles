{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "transparent",
  "keybinds": {
    "leader": "ctrl+o",
    "command_list": "<leader>:",
    "history_previous": "up,ctrl+p",
    "history_next": "down,ctrl+n",
    "messages_line_up": "ctrl+y",
    "messages_line_down": "ctrl+e",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d"
  }
}
